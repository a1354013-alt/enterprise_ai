# 後端環境變數

# OpenAI API (可選)
# OPENAI_API_KEY=sk-...

# CORS 允許的來源 (逗號分隔)
# 開發環境可使用 * 允許所有來源
# 生產環境應指定具體的來源，例如: http://localhost:3000,https://example.com
ALLOWED_ORIGINS=http://localhost:3000

# ChromaDB 路徑
CHROMA_DB_PATH=./chroma_db

# 資料庫路徑
DATABASE_PATH=documents.db

# 上傳目錄
UPLOAD_DIR=./uploads

# JWT 粒密鑰（必填）
# 建議使用強密碼，例如：openssl rand -hex 32
JWT_SECRET=your-secret-key-change-this-in-production

# 預設 admin 密碼（建議修改）
# 強密碼示例：MySecurePass123!@#
DEFAULT_ADMIN_PASSWORD=admin12345
